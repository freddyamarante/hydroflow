// HydroFlow Database Schema
// Hierarchy: GrupoCorporativo (optional) -> Empresa -> LocalProductivo -> Area -> Sector -> UnidadProduccion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Rol {
  ADMIN
  SUPERVISOR
  VISOR
}

enum Operador {
  MAYOR_QUE
  MENOR_QUE
  IGUAL_A
  DIFERENTE_DE
  FUERA_DE_RANGO
}

enum Severidad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

// ============================================
// AUTH & USERS
// ============================================

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  contrasena String
  nombre    String
  apellido  String?
  telefono  String?
  empresaId String?
  rol       Rol      @default(VISOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa             Empresa?                @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  localesProductivos  UsuarioLocalProductivo[]
  sectoresResponsable Sector[]

  @@map("usuario")
}

model UsuarioLocalProductivo {
  usuarioId        String
  localProductivoId String

  usuario         Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  localProductivo LocalProductivo @relation(fields: [localProductivoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, localProductivoId])
  @@map("usuario_local_productivo")
}

// ============================================
// ORGANIZATIONAL HIERARCHY
// ============================================

// Level 1: Corporate Group (OPTIONAL)
model GrupoCorporativo {
  id                    String   @id @default(cuid())
  razonSocial           String
  tipoIndustria         String?
  direccion             String?
  ubicacionDomiciliaria String?
  paginaWeb             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  empresas Empresa[]

  @@map("grupo_corporativo")
}

// Level 2: Company
model Empresa {
  id                    String   @id @default(cuid())
  razonSocial           String
  marcaComercial        String?
  ruc                   String?
  actividadEconomica    String?
  telefono              String?
  direccion             String?
  ubicacionDomiciliaria String?
  areaProduccion        String?
  paginaWeb             String?
  grupoCorporativoId    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  grupoCorporativo   GrupoCorporativo? @relation(fields: [grupoCorporativoId], references: [id], onDelete: SetNull)
  localesProductivos LocalProductivo[]
  usuarios           Usuario[]

  @@map("empresa")
}

// Level 3: Productive Location (farm, lab, etc.)
model LocalProductivo {
  id                    String   @id @default(cuid())
  nombre                String
  tipoProductivo        String?
  empresaId             String
  bounds                Json?
  areaProduccion        String?
  direccion             String?
  ubicacionDomiciliaria String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  empresa  Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  areas    Area[]
  usuarios UsuarioLocalProductivo[]

  @@map("local_productivo")
}

// Level 4: Area
model Area {
  id                  String   @id @default(cuid())
  nombre              String
  localProductivoId   String
  actividadProductiva String?
  bounds              Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  localProductivo LocalProductivo @relation(fields: [localProductivoId], references: [id], onDelete: Cascade)
  sectores        Sector[]

  @@map("area")
}

// Level 5: Sector
model Sector {
  id                    String   @id @default(cuid())
  nombre                String
  areaId                String
  tipo                  String?
  bounds                Json?
  detalles              Json?
  usuarioResponsableId  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  area                Area               @relation(fields: [areaId], references: [id], onDelete: Cascade)
  usuarioResponsable  Usuario?           @relation(fields: [usuarioResponsableId], references: [id], onDelete: SetNull)
  unidadesProduccion  UnidadProduccion[]

  @@map("sector")
}

// Level 6: Production Unit
model UnidadProduccion {
  id            String   @id @default(cuid())
  nombre        String
  sectorId      String
  posicion      Json?
  detalles      Json?
  tipoModuloId  String?
  topicMqtt     String   @unique
  configuracion Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sector   Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  lecturas Lectura[]
  reglas   Regla[]
  alertas  Alerta[]
  equipos  Equipo[]

  @@map("unidad_produccion")
}

// Level 7: Equipment
model Equipo {
  id                  String   @id @default(cuid())
  nombre              String
  tipo                String   // bomba, motor, reductor
  marca               String?
  modelo              String?
  especificaciones    Json?
  unidadProduccionId  String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  unidadProduccion UnidadProduccion @relation(fields: [unidadProduccionId], references: [id], onDelete: Cascade)

  @@map("equipo")
}

// ============================================
// SENSOR READINGS
// ============================================

model Lectura {
  id                  String   @id @default(cuid())
  unidadProduccionId  String
  timestamp           DateTime @default(now())
  valores             Json

  unidadProduccion UnidadProduccion @relation(fields: [unidadProduccionId], references: [id], onDelete: Cascade)

  @@index([unidadProduccionId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@map("lectura")
}

// ============================================
// RULES & ALERTS
// ============================================

model Regla {
  id                     String   @id @default(cuid())
  unidadProduccionId     String
  nombre                 String
  variable               String
  operador               Operador
  compararCon            String?
  valorFijo              Float?
  codigoEspecificacion   String?
  toleranciaPorcentaje   Float?
  severidad              Severidad
  activa                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  unidadProduccion UnidadProduccion @relation(fields: [unidadProduccionId], references: [id], onDelete: Cascade)

  @@map("regla")
}

model Alerta {
  id                  String    @id @default(cuid())
  unidadProduccionId  String
  reglaId             String?
  mensaje             String
  severidad           Severidad
  contexto            Json?
  resuelta            Boolean   @default(false)
  resueltaEn          DateTime?
  resueltaPor         String?
  creadaEn            DateTime  @default(now())

  unidadProduccion UnidadProduccion @relation(fields: [unidadProduccionId], references: [id], onDelete: Cascade)

  @@map("alerta")
}
