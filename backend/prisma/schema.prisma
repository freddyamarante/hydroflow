// HydroFlow Database Schema
// 7-level hierarchy: GrupoCorporativo (optional) -> Empresa -> Finca -> ProductionUnit -> Area -> Station -> PumpGroup -> Equipment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  assignedFincas         UserFinca[]
  responsibleForStations Station[]  // Stations this user is responsible for
}

enum Role {
  ADMIN
  SUPERVISOR
  VIEWER
}

model UserFinca {
  userId    String
  fincaId   String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  finca     Finca  @relation(fields: [fincaId], references: [id], onDelete: Cascade)

  @@id([userId, fincaId])
}

// ============================================
// ORGANIZATIONAL HIERARCHY (7 LEVELS)
// ============================================

// Level 1: Corporate Group (OPTIONAL)
model GrupoCorporativo {
  id        String    @id @default(cuid())
  nombre    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  empresas  Empresa[]

  @@map("grupo_corporativo")
}

// Level 2: Company (REQUIRED, may exist without corporate group)
model Empresa {
  id                  String             @id @default(cuid())
  nombre              String
  grupoCorporativoId  String?            // Now optional (nullable)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  grupoCorporativo    GrupoCorporativo?  @relation(fields: [grupoCorporativoId], references: [id], onDelete: SetNull)
  fincas              Finca[]

  @@map("empresa")
}

// Level 3: Farm (core operational unit)
model Finca {
  id          String    @id @default(cuid())
  nombre      String
  empresaId   String
  ubicacion   Json?     // { lat, lng, area } - General farm location
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  empresa          Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  productionUnits  ProductionUnit[] // Now has ProductionUnits instead of Sectors
  usuarios         UserFinca[]

  @@map("finca")
}

// Level 4: Production Unit (NEW - type of operation)
// Examples: Pumping operations, Aeration systems, etc.
model ProductionUnit {
  id        String          @id @default(cuid())
  nombre    String          // e.g., "Bombeo Principal", "Aireación Sector A"
  tipo      ProductionType  // Type of operation
  fincaId   String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  finca     Finca   @relation(fields: [fincaId], references: [id], onDelete: Cascade)
  areas     Area[]

  @@map("production_unit")
}

enum ProductionType {
  PUMPING      // Estaciones de bombeo
  AERATION     // Future: Aeration systems
  FEEDING      // Future: Automated feeding
  MONITORING   // Future: Monitoring stations
}

// Level 5: Area (RENAMED from Sector - physical zone within production unit)
// Examples: "Estación de Bombeo Norte", "Zona de Aireación 1"
model Area {
  id               String         @id @default(cuid())
  nombre           String         // Physical zone name
  productionUnitId String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  productionUnit   ProductionUnit @relation(fields: [productionUnitId], references: [id], onDelete: Cascade)
  stations         Station[]

  @@map("area")
}

// Level 6: Station (RENAMED from EstacionBombeo - specific station/unit)
// Examples: "Estación 5", "Bomba Norte 2"
model Station {
  id            String    @id @default(cuid())
  nombre        String    // Specific station name
  areaId        String
  coordinates   Json?     // { lat, lng } - Exact location for map placement
  responsibleId String?   // User responsible for this station
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  area          Area        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  responsible   User?       @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  pumpGroups    PumpGroup[]

  @@map("station")
}

// Level 7: Pump Group (individual pump unit within a station)
model PumpGroup {
  id              String      @id @default(cuid())
  nombre          String      // e.g., "Bomba 1", "Grupo A"
  stationId       String
  moduleType      ModuleType
  mqttTopic       String      @unique  // MQTT topic for this pump group
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  station         Station     @relation(fields: [stationId], references: [id], onDelete: Cascade)
  equipment       Equipment?  // 1:1 relationship (was 1:N)
  readings        Reading[]
  alerts          Alert[]
  rules           Rule[]

  @@map("pump_group")
}

enum ModuleType {
  DESCARGA_ABIERTA   // Open discharge
  DESCARGA_CERRADA   // Closed discharge
  COMPUERTA_RIO      // River gate
}

// ============================================
// EQUIPMENT (1:1 with PumpGroup - All Nominal Specs)
// ============================================

// Single equipment record per pump group
// Contains ALL nominal/theoretical specifications
// NOT reusable across pump groups
model Equipment {
  id              String    @id @default(cuid())
  pumpGroupId     String    @unique  // 1:1 relationship

  // Basic Information
  brand           String?   // Equipment brand/manufacturer
  model           String?   // Model number
  serialNumber    String?   // Serial number
  installDate     DateTime? // Installation date

  // Pump Specifications
  pumpType        String?   // Centrifugal, submersible, etc.
  pumpCapacity    Float?    // Flow capacity (m³/h)
  pumpHead        Float?    // Pump head (m)
  impellerSize    Float?    // Impeller diameter (mm)

  // Motor Specifications
  motorType       String?   // Electric, combustion, etc.
  motorPower      Float?    // Rated power (kW or HP)
  nominalVoltage  Float?    // Nominal voltage (V)
  nominalCurrent  Float?    // Nominal current (A)
  nominalRPM      Float?    // Nominal RPM
  motorEfficiency Float?    // Motor efficiency (%)
  powerFactor     Float?    // Power factor

  // Reducer/Gearbox (if applicable)
  hasReducer      Boolean   @default(false)
  reductionRatio  Float?    // Gear reduction ratio

  // Physical Parameters
  pipeInletSize   Float?    // Inlet pipe diameter (mm)
  pipeOutletSize  Float?    // Outlet pipe diameter (mm)

  // Additional specs (flexible JSON for future fields)
  additionalSpecs Json?     // Other specifications as needed

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pumpGroup       PumpGroup @relation(fields: [pumpGroupId], references: [id], onDelete: Cascade)

  @@map("equipment")
}

// ============================================
// SENSOR READINGS (TimescaleDB hypertable)
// ============================================

// Explicit columns instead of JSON blob
// Allows for proper indexing, aggregations, and queries
model Reading {
  id                  String    @id @default(cuid())
  pumpGroupId         String
  timestamp           DateTime  @default(now())

  // Flow & Level Measurements
  velocity            Float?    // Water velocity (m/s)
  level               Float?    // Water level (m)
  instantaneousFlow   Float?    // Instantaneous flow rate (m³/h)
  volume              Float?    // Volume pumped in this interval (m³) - calculated with actual time delta

  // Electrical Measurements
  voltage             Float?    // Voltage (V)
  current             Float?    // Current (A)
  power               Float?    // Power consumption (kW)
  powerFactor         Float?    // Power factor
  frequency           Float?    // Frequency (Hz)

  // Mechanical Measurements
  rpm                 Float?    // Revolutions per minute
  pressure            Float?    // Pressure (bar or PSI)
  temperature         Float?    // Temperature (°C)

  // Derived/Calculated Fields
  efficiency          Float?    // Calculated efficiency (%)

  // Energy Tracking
  energyConsumption   Float?    // Energy consumption from separate meter (kWh)

  // Backup for additional/future fields
  additionalData      Json?     // Any extra sensor data not in explicit columns

  pumpGroup           PumpGroup @relation(fields: [pumpGroupId], references: [id], onDelete: Cascade)

  @@index([pumpGroupId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@map("reading")
}

// ============================================
// RULES & ALERTS
// ============================================

// Rules for automated alert generation
// Compare sensor readings against equipment nominal values
model Rule {
  id              String    @id @default(cuid())
  pumpGroupId     String
  variable        String    // Sensor variable: "voltage", "current", "rpm", etc.
  operator        Operator  // Comparison operator
  referenceValue  Float     // From Equipment specs
  tolerance       Float     // Tolerance percentage (e.g., 5 for ±5%)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pumpGroup       PumpGroup @relation(fields: [pumpGroupId], references: [id], onDelete: Cascade)

  @@map("rule")
}

enum Operator {
  GREATER_THAN        // >
  LESS_THAN           // <
  EQUAL_TO            // =
  NOT_EQUAL_TO        // !=
  OUT_OF_RANGE        // Outside tolerance range
}

// System-generated alerts based on rules or sensor disconnections
model Alert {
  id              String     @id @default(cuid())
  pumpGroupId     String
  type            AlertType  // Alert type
  message         String     // Alert message (Spanish for users)
  severity        Severity   // Alert severity level
  readingSnapshot Json?      // Sensor data when alert triggered
  isResolved      Boolean    @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?    // User ID who resolved the alert
  notes           String?    // Resolution notes
  createdAt       DateTime   @default(now())

  pumpGroup       PumpGroup  @relation(fields: [pumpGroupId], references: [id], onDelete: Cascade)

  @@index([pumpGroupId, createdAt(sort: Desc)])
  @@index([isResolved, createdAt(sort: Desc)])
  @@map("alert")
}

enum AlertType {
  SENSOR_DISCONNECTED  // Sensor lost connection
  VALUE_OUT_OF_RANGE   // Value outside acceptable range
  RULE_VIOLATION       // Rule condition violated
  EQUIPMENT_FAILURE    // Equipment failure detected
  HIGH_ENERGY_USAGE    // Abnormal energy consumption
}

enum Severity {
  LOW       // Informational
  MEDIUM    // Warning
  HIGH      // Critical
  CRITICAL  // Immediate action required
}
